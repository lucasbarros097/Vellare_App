# ============================================
# Vellare Doces — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# Comando: cp .env.example .env

# ---------- PostgreSQL ----------
POSTGRES_USER=vellare_user
POSTGRES_PASSWORD=vellare_pass
POSTGRES_DB=vellare_db

# ---------- Database URL (usado pelo FastAPI/SQLAlchemy) ----------
DATABASE_URL=postgresql://vellare_user:vellare_pass@db:5432/vellare_db

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000

# ---------- CORS ----------
# Origens permitidas separadas por vírgula.
# Dev local: http://localhost,http://localhost:80
# Produção: https://seu-dominio.vercel.app
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ---------- Admin ----------
# Chave simples de autenticação para rotas /api/admin/*
ADMIN_KEY=senha_painel_admin